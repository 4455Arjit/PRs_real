# PostgreSQL / Supabase
PG_user=postgres
PG_host=db.your-project-ref.supabase.co
PG_database=postgres
PG_pass=your_database_password
PG_port=5432

# Session secret (use a long random string)
Session_key=replace_with_long_random_secret

# App domain on Vercel (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# Optional (app can auto-detect in production)
API_URL=https://your-app.vercel.app

# Runtime
NODE_ENV=production
