<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - World Chat(Anonymous)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --bg-primary: #0d1117;
            --bg-secondary: #161b22;
            --bg-card: #21262d;
            --border-color: #30363d;
            --text-primary: #f0f6fc;
            --text-secondary: #8b949e;
            --accent-primary: #58a6ff;
            --accent-secondary: #238636;
            --accent-danger: #da3633;
            --accent-warning: #d29922;
            --accent-purple: #a371f7;
            --input-bg: #0d1117;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
        }

        .navbar-custom {
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
            padding: 0.75rem 0;
        }

        .navbar-custom .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.2s ease;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .navbar-custom .nav-link:hover {
            color: var(--accent-primary);
            background: rgba(88, 166, 255, 0.08);
        }

        .login-container {
            min-height: calc(100vh - 70px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background:
                radial-gradient(ellipse at center, rgba(88, 166, 255, 0.05) 0%, transparent 70%);
        }

        .login-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-icon {
            font-size: 2.5rem;
            color: var(--accent-primary);
            margin-bottom: 1rem;
        }

        .login-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .login-subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .form-label {
            color: var(--text-secondary);
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .form-control-modern {
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            color: var(--text-primary);
            padding: 0.875rem 1rem;
            font-size: 1rem;
            transition: all 0.2s ease;
        }

        .form-control-modern:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.15);
            background: var(--input-bg);
        }

        .form-control-modern::placeholder {
            color: var(--text-secondary);
            opacity: 0.7;
        }

        .btn-submit {
            width: 100%;
            padding: 0.875rem;
            background: linear-gradient(135deg, var(--accent-primary), #4393e6);
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(88, 166, 255, 0.35);
        }

        .error-container {
            margin-top: 1.5rem;
        }

        .error-message {
            background: rgba(218, 54, 51, 0.1);
            border: 1px solid rgba(218, 54, 51, 0.3);
            border-radius: 10px;
            padding: 1rem;
            text-align: center;
            color: #ff7b72;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .error-message.warning {
            background: rgba(210, 153, 34, 0.1);
            border-color: rgba(210, 153, 34, 0.3);
            color: var(--accent-warning);
        }

        .input-group-icon {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            z-index: 10;
        }

        .input-group-icon .form-control {
            padding-left: 2.75rem;
        }

        @media (max-width: 480px) {
            .login-card {
                padding: 1.5rem;
            }

            .navbar-custom .container {
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar-custom">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="/" class="nav-link">
                <i class="bi bi-arrow-left"></i>
                Back to Home
            </a>
            <a href="/regis" class="nav-link">
                <i class="bi bi-person-plus"></i>
                Register
            </a>
        </div>
    </nav>

    <!-- Login Form -->
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="login-icon">
                    <i class="bi bi-person-circle"></i>
                </div>
                <h2 class="login-title">Welcome Back</h2>
                <p class="login-subtitle">Sign in to continue to World Chat</p>
            </div>

            <form action="/userLogin" method="post">
                <div class="mb-3">
                    <label for="user_name" class="form-label">Email Address</label>
                    <div class="input-group-icon">
                        <span class="input-icon"><i class="bi bi-envelope"></i></span>
                        <input type="email"
                               class="form-control form-control-modern"
                               name="user_email"
                               id="user_name"
                               placeholder="Enter your email"
                               <% if(locals.usermail) { %> value="<%= usermail %>" <% } %>
                               required>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="user_pass" class="form-label">Password</label>
                    <div class="input-group-icon">
                        <span class="input-icon"><i class="bi bi-lock"></i></span>
                        <input type="password"
                               class="form-control form-control-modern"
                               name="user_pass"
                               id="user_pass"
                               placeholder="Enter your password"
                               required>
                    </div>
                </div>

                <button class="btn-submit" type="submit">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Sign In
                </button>
            </form>

            <!-- Error Messages -->
            <div class="error-container">
                <% if(locals.pass_error) { %>
                    <div class="error-message">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span><%= pass_error %></span>
                    </div>
                <% } else if(locals.not_exist_error) { %>
                    <div class="error-message warning">
                        <i class="bi bi-info-circle"></i>
                        <span><%= not_exist_error %></span>
                    </div>
                <% } else if(locals.login_again_error) { %>
                    <div class="error-message warning">
                        <i class="bi bi-clock-history"></i>
                        <span><%= login_again_error %></span>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
