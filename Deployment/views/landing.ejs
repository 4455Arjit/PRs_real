<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World Chat (Anonymous) - Connect & Share</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --bg-primary: #0d1117;
            --bg-secondary: #161b22;
            --bg-card: #21262d;
            --border-color: #30363d;
            --text-primary: #f0f6fc;
            --text-secondary: #8b949e;
            --accent-primary: #58a6ff;
            --accent-secondary: #238636;
            --accent-danger: #da3633;
            --accent-warning: #d29922;
            --accent-purple: #a371f7;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .landing-container {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            position: relative;
            background:
                radial-gradient(ellipse at top right, rgba(88, 166, 255, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at bottom left, rgba(163, 113, 247, 0.08) 0%, transparent 50%),
                var(--bg-primary);
        }

        .brand-section {
            text-align: center;
            margin-bottom: 3rem;
        }

        .brand-icon {
            font-size: 4rem;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }

        .brand-title {
            font-size: 3rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, var(--text-primary), var(--accent-primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand-subtitle {
            font-size: 1.1rem;
            color: var(--text-secondary);
            max-width: 400px;
        }

        .action-buttons {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            width: 100%;
            max-width: 320px;
        }

        .btn-modern {
            padding: 1rem 2rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            text-decoration: none;
            text-align: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }

        .btn-register {
            background: linear-gradient(135deg, var(--accent-secondary), #2ea043);
            color: white;
            border: none;
            box-shadow: 0 4px 15px rgba(35, 134, 54, 0.3);
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(35, 134, 54, 0.4);
            color: white;
        }

        .btn-login {
            background: transparent;
            color: var(--accent-primary);
            border: 2px solid var(--accent-primary);
        }

        .btn-login:hover {
            background: rgba(88, 166, 255, 0.1);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(88, 166, 255, 0.2);
            color: var(--accent-primary);
        }

        .features-section {
            margin-top: 4rem;
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .feature-item i {
            color: var(--accent-primary);
        }

        @media (max-width: 480px) {
            .brand-title {
                font-size: 2.2rem;
            }

            .btn-modern {
                padding: 0.875rem 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="landing-container">
        <div class="brand-section">
            <div class="brand-icon">
                <i class="bi bi-chat-dots-fill"></i>
            </div>
            <h1 class="brand-title">Anonymous Chat</h1>
            <p class="brand-subtitle">Connect with your community. Share ideas, earn rewards, and engage with content that matters.</p>
        </div>

        <div class="action-buttons">
            <a href="/regis" class="btn-modern btn-register">
                <i class="bi bi-person-plus-fill"></i>
                Create Account
            </a>
            <a href="/login" class="btn-modern btn-login">
                <i class="bi bi-box-arrow-in-right"></i>
                Sign In
            </a>
        </div>

        <div class="features-section">
            <div class="feature-item">
                <i class="bi bi-shield-check"></i>
                <span>Secure Auth</span>
            </div>
            <div class="feature-item">
                <i class="bi bi-lightning-charge"></i>
                <span>Real-time Feed</span>
            </div>
            <div class="feature-item">
                <i class="bi bi-star"></i>
                <span>Earn Points</span>
            </div>
        </div>
    </div>
</body>
</html>
